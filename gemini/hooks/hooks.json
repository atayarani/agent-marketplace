{
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/reviewers/prompt_require_diff.sh\""
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/wiki_keeper/protect_raw_sources.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/wiki_keeper/protect_normalized_synthesis.sh\""
          }
        ]
      }
    ]
  }
}
